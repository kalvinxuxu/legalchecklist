# Fly.io 生产环境配置（PostgreSQL 15 + Chroma）

# 环境配置
ENVIRONMENT=production

# PostgreSQL 15 - 通过 Fly secrets 设置 DATABASE_URL
# 运行：fly secrets set DATABASE_URL="postgres://..."
DATABASE_TYPE=postgresql

# Chroma 向量数据库持久化目录
CHROMA_PERSIST_DIR=/app/data/chroma

# JWT 配置
# 运行：fly secrets set JWT_SECRET=$(openssl rand -hex 32)
JWT_SECRET=your-jwt-secret-here

# 智谱 AI API
ZHIPU_API_KEY=de4f2b05ed614848b844a77928dbcb3e.nUbrXEpkVAnpD62O
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4
ZHIPU_EMBEDDING_MODEL=embedding-2

# DeepSeek API（Embedding 使用）
DEEPSEEK_API_KEY=${DEEPSEEK_API_KEY}
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_EMBEDDING_MODEL=deepseek-embedding

# 文件存储（本地）
STORAGE_TYPE=local
STORAGE_PATH=/app/data/uploads

# CORS（生产环境）
CORS_ORIGINS=["https://legal-ai-saas-kalvi.fly.dev"]

# Celery 已禁用，使用 asyncio
USE_CELERY=false
