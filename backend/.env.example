# 环境配置
ENVIRONMENT=development

# 数据库配置
# 本地开发使用 SQLite (无需安装数据库)
DATABASE_TYPE=sqlite
SQLITE_PATH=./legal_saas.db

# 生产环境使用 PostgreSQL 15
# DATABASE_TYPE=postgresql
# DATABASE_URL=postgresql://postgres:password@localhost:5432/legal_saas

# Chroma 向量数据库（本地开发使用 SQLite 时仍需要 Chroma）
CHROMA_PERSIST_DIR=./data/chroma

# Redis（本地开发可不启用）
# REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 智谱 AI API（主推）
ZHIPU_API_KEY=your_zhipu_api_key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4
ZHIPU_EMBEDDING_MODEL=embedding-2

# DeepSeek API（Embedding 使用）
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_EMBEDDING_MODEL=deepseek-embedding

# 阿里云 OSS 和文档智能
ALIYUN_ACCESS_KEY_ID=your_aliyun_key
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_secret
ALIYUN_OSS_BUCKET=legal-saas
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# Celery 异步任务队列（生产环境）
USE_CELERY=false
REDIS_URL=redis://localhost:6379/0
