# PostgreSQL + pgvector 配置示例
# 复制此文件为 .env.postgresql 并修改对应配置

# 环境配置
ENVIRONMENT=development

# ========== 数据库（PostgreSQL + pgvector）==========
DATABASE_TYPE=postgresql
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/legal_saas

# 如果使用外部 PostgreSQL（如阿里云RDS）
# DATABASE_URL=postgresql://user:password@pg-xxxxx.pg.rds.aliyuncs.com:5432/legal_saas

# ========== SQLite（仅保留用于参考，部署后禁用）==========
# DATABASE_TYPE=sqlite
# SQLITE_PATH=./legal_saas.db

# ========== 向量维度配置 ==========
# DeepSeek embedding 维度为 1536
EMBEDDING_DIMENSION=1536

# ========== JWT ==========
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ========== DeepSeek API（主推）==========
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_EMBEDDING_MODEL=deepseek-embedding

# ========== MiniMax API（视觉理解）==========
MINIMAX_API_KEY=sk-your-minimax-api-key
MINIMAX_VISION_MODEL=MiniMax-VL-01

# ========== 文件存储 ==========
STORAGE_TYPE=local
STORAGE_PATH=./uploads
