# ============================================
# Legal AI SaaS 环境变量配置
# ============================================
# 复制此文件为 .env 并填写真实值
# 警告: 不要将 .env 提交到版本控制系统!
# ============================================

# ============ 数据库配置 ============
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_USER=postgres
POSTGRES_DB=legal_saas

# ============ 应用密钥 ============
# JWT 密钥 - 生产环境必须使用复杂的随机字符串
JWT_SECRET=change_this_to_a_secure_random_string_at_least_32_chars

# ============ API 密钥 ============
# DeepSeek API 密钥（用于 LLM 服务）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ============ Fly.io 配置 ============
# 仅在 Fly.io 部署时需要
# FLY_API_TOKEN=your-fly-io-token

# ============ SSL 证书路径 ============
# 生产环境 SSL 证书（挂载到 /etc/nginx/ssl/）
# SSL_CERT_PATH=./ssl/cert.pem
# SSL_CERT_KEY_PATH=./ssl/key.pem

# ============ Chroma 向量数据库 ============
CHROMA_PERSIST_DIR=/app/data/chroma

# ============ Redis 配置 ============
REDIS_URL=redis://redis:6379

# ============ CORS 配置 ============
# 允许的跨域来源（前端地址）
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============ 文件上传配置 ============
MAX_FILE_SIZE=52428800
ALLOWED_EXTENSIONS=pdf,docx

# ============ 应用配置 ============
APP_ENV=production
LOG_LEVEL=info
